# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================
# Get these from: https://dashboard.stripe.com/apikeys

# Stripe Publishable Key (safe to expose in frontend)
STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefghijklmnopqrstuvwxyz

# Stripe Secret Key (server-side only - NEVER expose this)
STRIPE_SECRET_KEY=sk_test_abcdefghijklmnopqrstuvwxyz1234567890

# Stripe Webhook Secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET=whsec_abcdefghijklmnopqrstuvwxyz

# Public key for Next.js (accessible from frontend)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefghijklmnopqrstuvwxyz

# ============================================================================
# PAYPAL CONFIGURATION
# ============================================================================
# Get these from: https://developer.paypal.com/dashboard/

# PayPal Mode: 'sandbox' for testing, 'production' for live
PAYPAL_MODE=sandbox

# PayPal Client ID
PAYPAL_CLIENT_ID=AEj1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# PayPal Client Secret (server-side only - NEVER expose this)
PAYPAL_CLIENT_SECRET=EL1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# Public client ID for Next.js (accessible from frontend)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AEj1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# PayPal Webhook ID (optional)
PAYPAL_WEBHOOK_ID=abcdef123456

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api
# Supabase URL (the API endpoint)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (safe to expose in frontend - respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (server-side only - NEVER expose this)
# This key bypasses RLS for server-side operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secret key for JWT token signing/verification
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Public API URL (used in emails, redirects, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SENDER_EMAIL=noreply@yourecommerce.com
SENDER_NAME=Fain si Punct

# ============================================================================
# UPSTASH REDIS CONFIGURATION (Background Job Queue)
# ============================================================================
# Get these from: https://console.upstash.com/redis
# Upstash Redis REST URL (for serverless/edge environments)
UPSTASH_REDIS_REST_URL=https://your-project.upstash.io

# Upstash Redis REST Token (for authentication)
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Email job queue configuration
EMAIL_QUEUE_NAME=email-jobs
EMAIL_MAX_RETRIES=4

# ============================================
# REVOLUT PAYMENTS (Romanian market)
# ============================================
REVOLUT_API_KEY=
REVOLUT_ENVIRONMENT=sandbox
NEXT_PUBLIC_REVOLUT_PUBLIC_ID=
REVOLUT_WEBHOOK_SECRET=

# ============================================
# OBLIO INVOICING (Romanian e-factura)
# ============================================
OBLIO_API_KEY=
OBLIO_API_SECRET=
OBLIO_COMPANY_CIF=

# ============================================
# SAMEDAY COURIER (Romanian delivery)
# ============================================
SAMEDAY_USERNAME=
SAMEDAY_PASSWORD=
SAMEDAY_ENVIRONMENT=sandbox
SAMEDAY_PICKUP_POINT_ID=
SAMEDAY_SERVICE_ID=

# ============================================================================
# SECURITY & RATE LIMITING
# ============================================================================
# Rate limiting configuration
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
CHECKOUT_RATE_LIMIT_MAX=10  # Per hour
PAYMENT_RATE_LIMIT_MAX=20   # Per hour

# Max request payload size
MAX_PAYLOAD_SIZE=10mb

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
# Sentry error tracking (optional, for production)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Node environment
NODE_ENV=development

# ============================================================================
# NOTES
# ============================================================================
# 1. For local development:
#    - Copy this file to .env.local
#    - Replace all xxx values with your actual test credentials
#    - Use Stripe test keys (pk_test_*, sk_test_*)
#    - Use PayPal sandbox credentials
#    - Set up Supabase project and get URL + keys from project settings
#    - Set up Upstash Redis and get REST URL + token
#
# 2. For production:
#    - Use Stripe live keys (pk_live_*, sk_live_*)
#    - Use PayPal production credentials
#    - Change PAYPAL_MODE to 'production'
#    - Use a strong, random JWT_SECRET
#    - Use Supabase production project
#    - Use Upstash Redis production instance
#    - Store all secrets securely (use platform's secrets manager)
#
# 3. Database setup (Supabase):
#    - Create new Supabase project
#    - Run SQL migrations from /supabase/schema.sql in Supabase dashboard
#    - Enable Row-Level Security (RLS) policies if needed
#
# 4. Job queue setup (Upstash):
#    - Create new Upstash Redis database
#    - Use REST API (no direct TCP connection on Vercel)
#    - Configure retry settings in environment variables
#
# 5. NEVER commit this file with real credentials
# 6. NEVER expose STRIPE_SECRET_KEY, PAYPAL_CLIENT_SECRET, or SUPABASE_SERVICE_ROLE_KEY in frontend code
# 7. Always use HTTPS in production
