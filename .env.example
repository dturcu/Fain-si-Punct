# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================
# Get these from: https://dashboard.stripe.com/apikeys

# Stripe Publishable Key (safe to expose in frontend)
STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefghijklmnopqrstuvwxyz

# Stripe Secret Key (server-side only - NEVER expose this)
STRIPE_SECRET_KEY=sk_test_abcdefghijklmnopqrstuvwxyz1234567890

# Stripe Webhook Secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET=whsec_abcdefghijklmnopqrstuvwxyz

# Public key for Next.js (accessible from frontend)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefghijklmnopqrstuvwxyz

# ============================================================================
# PAYPAL CONFIGURATION
# ============================================================================
# Get these from: https://developer.paypal.com/dashboard/

# PayPal Mode: 'sandbox' for testing, 'production' for live
PAYPAL_MODE=sandbox

# PayPal Client ID
PAYPAL_CLIENT_ID=AEj1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# PayPal Client Secret (server-side only - NEVER expose this)
PAYPAL_CLIENT_SECRET=EL1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# Public client ID for Next.js (accessible from frontend)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AEj1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# PayPal Webhook ID (optional)
PAYPAL_WEBHOOK_ID=abcdef123456

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ecommerce

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secret key for JWT token signing/verification
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Public API URL (used in emails, redirects, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SENDER_EMAIL=noreply@yourecommerce.com
SENDER_NAME=ShopHub

# ============================================================================
# BACKGROUND JOB QUEUE (Bull + Redis)
# ============================================================================
# Redis connection string for Bull job queue
REDIS_URL=redis://localhost:6379

# Email job queue configuration
EMAIL_QUEUE_NAME=email-jobs
EMAIL_MAX_RETRIES=4

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Node environment
NODE_ENV=development

# ============================================================================
# NOTES
# ============================================================================
# 1. For local development:
#    - Copy this file to .env.local
#    - Replace all xxx values with your actual test credentials
#    - Use Stripe test keys (pk_test_*, sk_test_*)
#    - Use PayPal sandbox credentials
#
# 2. For production:
#    - Use Stripe live keys (pk_live_*, sk_live_*)
#    - Use PayPal production credentials
#    - Change PAYPAL_MODE to 'production'
#    - Use a strong, random JWT_SECRET
#    - Store all secrets securely (use platform's secrets manager)
#
# 3. NEVER commit this file with real credentials
# 4. NEVER expose STRIPE_SECRET_KEY or PAYPAL_CLIENT_SECRET in frontend code
# 5. Always use HTTPS in production
